---
/**
 * ModeToggle — three-mode switcher (light / dark / vibrant).
 *
 * Writes data-mode on <html> and persists the choice in localStorage under
 * `memopop-mode`. The pre-paint inline script in BaseLayout reads this same
 * key to apply the mode before CSS evaluates, avoiding FOUC.
 *
 * Pure HTML + vanilla JS. No framework state.
 */
---

<fieldset class="mode-toggle" role="radiogroup" aria-label="Color mode">
  <legend class="mode-toggle__legend">Mode</legend>
  <button type="button" class="mode-toggle__btn" data-mode="light" aria-label="Light mode" title="Boardroom (light)">
    <span class="mode-toggle__glyph" aria-hidden="true">
      <svg viewBox="0 0 16 16" width="14" height="14">
        <circle cx="8" cy="8" r="3.2" fill="currentColor" />
        <g stroke="currentColor" stroke-width="1.4" stroke-linecap="round">
          <line x1="8" y1="1" x2="8" y2="3" />
          <line x1="8" y1="13" x2="8" y2="15" />
          <line x1="1" y1="8" x2="3" y2="8" />
          <line x1="13" y1="8" x2="15" y2="8" />
          <line x1="3" y1="3" x2="4.5" y2="4.5" />
          <line x1="11.5" y1="11.5" x2="13" y2="13" />
          <line x1="3" y1="13" x2="4.5" y2="11.5" />
          <line x1="11.5" y1="4.5" x2="13" y2="3" />
        </g>
      </svg>
    </span>
    <span class="mode-toggle__label">Light</span>
  </button>
  <button type="button" class="mode-toggle__btn" data-mode="dark" aria-label="Dark mode" title="Operator (dark)">
    <span class="mode-toggle__glyph" aria-hidden="true">
      <svg viewBox="0 0 16 16" width="14" height="14">
        <path d="M 11.5 9.5 a 5 5 0 1 1 -5 -7 a 4 4 0 0 0 5 7 z" fill="currentColor" />
      </svg>
    </span>
    <span class="mode-toggle__label">Dark</span>
  </button>
  <button type="button" class="mode-toggle__btn" data-mode="vibrant" aria-label="Vibrant mode" title="Demo (vibrant)">
    <span class="mode-toggle__glyph" aria-hidden="true">
      <svg viewBox="0 0 16 16" width="14" height="14">
        <circle cx="6" cy="6" r="3.2" fill="var(--color-accent-hot)" opacity="0.85" />
        <circle cx="10" cy="10" r="3.2" fill="var(--color-thread)" opacity="0.85" />
        <circle cx="6" cy="10" r="2.4" fill="var(--color-accent-warm)" opacity="0.85" />
      </svg>
    </span>
    <span class="mode-toggle__label">Vibrant</span>
  </button>
</fieldset>

<style>
  .mode-toggle {
    display: inline-flex;
    align-items: stretch;
    gap: 0;
    padding: 3px;
    margin: 0;
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-pill);
    background: color-mix(in oklab, var(--color-text) 4%, transparent);
  }
  .mode-toggle__legend {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip-path: inset(50%);
    white-space: nowrap;
  }
  .mode-toggle__btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    border: none;
    background: transparent;
    color: var(--color-text-dim);
    font-family: var(--font__mono);
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    border-radius: var(--radius-pill);
    cursor: pointer;
    transition: color 180ms ease, background 180ms ease, transform 180ms ease;
  }
  .mode-toggle__btn:hover { color: var(--color-text); }
  .mode-toggle__btn:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }
  .mode-toggle__btn[aria-pressed='true'] {
    background: var(--color-bg-elevated);
    color: var(--color-accent);
    box-shadow: var(--shadow-card);
  }
  .mode-toggle__glyph {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: currentColor;
  }
  @media (max-width: 720px) {
    .mode-toggle__label { display: none; }
    .mode-toggle__btn { padding: 6px 9px; }
  }
</style>

<script>
  type Mode = 'light' | 'dark' | 'vibrant';
  const STORAGE_KEY = 'memopop-mode';

  function applyMode(mode: Mode): void {
    document.documentElement.setAttribute('data-mode', mode);
    document.querySelectorAll<HTMLButtonElement>('.mode-toggle__btn').forEach((btn) => {
      btn.setAttribute('aria-pressed', btn.dataset.mode === mode ? 'true' : 'false');
    });
  }

  function readPersisted(): Mode {
    try {
      const v = localStorage.getItem(STORAGE_KEY);
      if (v === 'light' || v === 'dark' || v === 'vibrant') return v;
    } catch { /* noop */ }
    const current = document.documentElement.getAttribute('data-mode');
    if (current === 'light' || current === 'vibrant') return current;
    return 'dark';
  }

  applyMode(readPersisted());

  document.querySelectorAll<HTMLButtonElement>('.mode-toggle__btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const mode = btn.dataset.mode as Mode | undefined;
      if (!mode) return;
      applyMode(mode);
      try { localStorage.setItem(STORAGE_KEY, mode); } catch { /* noop */ }
    });
  });
</script>
