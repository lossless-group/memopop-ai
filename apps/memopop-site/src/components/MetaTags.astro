---
import type { SeoMeta } from '@lib/seo';

interface Props {
  seo: SeoMeta;
}

const { seo } = Astro.props;
---

<title>{seo.title}</title>
<meta name="description" content={seo.description} />
<link rel="canonical" href={seo.canonical} />
{seo.noindex && <meta name="robots" content="noindex, nofollow" />}

{/* Open Graph */}
<meta property="og:type" content={seo.ogType} />
<meta property="og:title" content={seo.title} />
<meta property="og:description" content={seo.description} />
<meta property="og:url" content={seo.canonical} />
<meta property="og:site_name" content="MemoPop AI" />
<meta property="og:locale" content="en_US" />

{seo.ogImage && (
  <>
    <meta property="og:image" content={seo.ogImage.url} />
    {seo.ogImage.alt && <meta property="og:image:alt" content={seo.ogImage.alt} />}
    {seo.ogImage.type && <meta property="og:image:type" content={seo.ogImage.type} />}
    {seo.ogImage.width && <meta property="og:image:width" content={String(seo.ogImage.width)} />}
    {seo.ogImage.height && <meta property="og:image:height" content={String(seo.ogImage.height)} />}
  </>
)}

{seo.publishedTime && <meta property="article:published_time" content={seo.publishedTime} />}
{seo.modifiedTime && <meta property="article:modified_time" content={seo.modifiedTime} />}
{seo.author && <meta property="article:author" content={seo.author} />}
{seo.tags?.map((tag) => <meta property="article:tag" content={tag} />)}

{/* Twitter */}
<meta name="twitter:card" content={seo.twitterCard} />
{seo.twitterSite && <meta name="twitter:site" content={seo.twitterSite} />}
{seo.twitterCreator && <meta name="twitter:creator" content={seo.twitterCreator} />}
<meta name="twitter:title" content={seo.title} />
<meta name="twitter:description" content={seo.description} />
{seo.ogImage && <meta name="twitter:image" content={seo.ogImage.url} />}
{seo.ogImage?.alt && <meta name="twitter:image:alt" content={seo.ogImage.alt} />}

{/* JSON-LD */}
{seo.jsonLd && (
  <script type="application/ld+json" set:html={JSON.stringify(seo.jsonLd)} />
)}
