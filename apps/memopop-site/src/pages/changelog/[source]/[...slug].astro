---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';

type Source = 'orchestrator' | 'native' | 'site' | 'monorepo';

const SOURCE_META = {
  orchestrator: { label: 'Orchestrator', collection: 'changelog-orchestrator' as const },
  native:       { label: 'Native',       collection: 'changelog-native' as const },
  site:         { label: 'Site',         collection: 'changelog-site' as const },
  monorepo:     { label: 'Monorepo',     collection: 'changelog-monorepo' as const },
} satisfies Record<Source, { label: string; collection: string }>;

export async function getStaticPaths() {
  const sources: Source[] = ['orchestrator', 'native', 'site', 'monorepo'];
  const collections = {
    orchestrator: 'changelog-orchestrator',
    native:       'changelog-native',
    site:         'changelog-site',
    monorepo:     'changelog-monorepo',
  } as const;

  const paths = [];
  for (const source of sources) {
    const entries = await getCollection(collections[source]);
    for (const entry of entries) {
      paths.push({
        params: { source, slug: entry.id },
        props: { entry, source },
      });
    }
  }
  return paths;
}

interface Props {
  entry: CollectionEntry<'changelog-orchestrator' | 'changelog-native' | 'changelog-site' | 'changelog-monorepo'>;
  source: Source;
}

const { entry, source } = Astro.props as Props;
const { Content } = await render(entry);
const data = entry.data as Record<string, unknown>;

function deriveDateFromId(id: string): Date | null {
  const match = id.match(/^(\d{4}-\d{2}-\d{2})/);
  if (!match) return null;
  const d = new Date(match[1]);
  return Number.isNaN(d.getTime()) ? null : d;
}

function pickDate(): Date | null {
  const candidates = [
    'date_authored_initial_draft',
    'date',
    'date_first_published',
    'date_authored_current_draft',
    'date_created',
    'date_modified',
    'date_last_updated',
  ];
  for (const key of candidates) {
    const v = data[key];
    if (v instanceof Date && !Number.isNaN(v.getTime())) return v;
  }
  return deriveDateFromId(entry.id);
}

function pickString(...keys: string[]): string | undefined {
  for (const k of keys) {
    const v = data[k];
    if (typeof v === 'string' && v.trim()) return v;
  }
  return undefined;
}

const title = pickString('title') ?? entry.id;
const summary = pickString('lede', 'summary', 'description');
const date = pickDate();
const version = pickString('at_semantic_version');
const status = pickString('status');
const category = pickString('category');
const augmentedWith = pickString('augmented_with');
const tags = Array.isArray(data.tags) ? (data.tags as string[]) : [];
const authors = Array.isArray(data.authors) ? (data.authors as string[]) : [];

const dateFmt = (d: Date | null) =>
  d
    ? d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' })
    : null;

const base = import.meta.env.BASE_URL;
---

<BaseLayout title={`${title} — Changelog`}>
  <main class="main-content">
    <div class="container">
      <a href={`${base}changelog`} class="back-link">← All changelog entries</a>

      <header class="entry-header">
        <div class="header-meta">
          <span class={`source-badge src-${source}`}>{SOURCE_META[source].label}</span>
          {date && <time class="entry-date">{dateFmt(date)}</time>}
          {version && <span class="entry-version">v{version}</span>}
          {status && <span class="entry-status">{status}</span>}
          {category && <span class="entry-category">{category}</span>}
        </div>

        <h1 class="entry-title">{title}</h1>
        {summary && <p class="entry-lede">{summary}</p>}

        {(authors.length > 0 || augmentedWith) && (
          <div class="byline">
            {authors.length > 0 && <span>By {authors.join(', ')}</span>}
            {augmentedWith && <span class="augmented">augmented with {augmentedWith}</span>}
          </div>
        )}

        {tags.length > 0 && (
          <div class="entry-tags">
            {tags.map(tag => <span class="tag">{tag}</span>)}
          </div>
        )}
      </header>

      <article class="entry-body">
        <Content />
      </article>
    </div>
  </main>
</BaseLayout>

<style>
  .main-content {
    min-height: 100vh;
    padding: 2rem 0 4rem;
  }

  .container {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .back-link {
    display: inline-block;
    font-size: 0.85rem;
    color: var(--clr-lossless-accent--aquamarine);
    text-decoration: none;
    margin-bottom: 1.5rem;
    transition: color 0.2s;
  }

  .back-link:hover { color: var(--clr-lossless-accent--brightest); }

  .entry-header {
    padding-bottom: 2rem;
    margin-bottom: 2rem;
    border-bottom: 1px solid var(--clr-border-subtle);
  }

  .header-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
    font-size: 0.8rem;
  }

  .source-badge {
    padding: 0.18rem 0.6rem;
    border-radius: 4px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 0.7rem;
  }

  .src-orchestrator { background: rgba(4, 229, 229, 0.12); color: var(--clr-lossless-accent--brightest); border: 1px solid rgba(4, 229, 229, 0.3); }
  .src-native       { background: rgba(111, 255, 214, 0.10); color: var(--clr-lossless-accent--aquamarine); border: 1px solid rgba(111, 255, 214, 0.3); }
  .src-site         { background: rgba(191, 35, 247, 0.10); color: #d98ff5; border: 1px solid rgba(191, 35, 247, 0.3); }
  .src-monorepo     { background: rgba(234, 179, 8, 0.10); color: #fde047; border: 1px solid rgba(234, 179, 8, 0.3); }

  .entry-date, .entry-version, .entry-status, .entry-category {
    color: var(--clr-lossless-primary-dim);
  }

  .entry-version {
    font-family: var(--ff-monospace);
    font-size: 0.74rem;
  }

  .entry-title {
    font-size: clamp(1.6rem, 3.5vw, 2.25rem);
    font-weight: 700;
    color: var(--clr-lossless-primary);
    line-height: 1.25;
    margin: 0 0 0.85rem 0;
  }

  .entry-lede {
    font-size: 1.15rem;
    color: var(--clr-lossless-primary-light);
    line-height: 1.65;
    margin: 0 0 1.25rem 0;
  }

  .byline {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    font-size: 0.85rem;
    color: var(--clr-lossless-primary-dim);
    margin-bottom: 1rem;
  }

  .augmented { font-style: italic; }

  .entry-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tag {
    font-size: 0.72rem;
    padding: 0.2rem 0.55rem;
    border-radius: 4px;
    background: rgba(255, 255, 255, 0.04);
    color: var(--clr-lossless-primary-light);
    font-family: var(--ff-monospace);
  }

  .entry-body {
    color: var(--clr-lossless-primary);
    font-size: 1rem;
    line-height: 1.75;
  }

  .entry-body :global(h1),
  .entry-body :global(h2),
  .entry-body :global(h3),
  .entry-body :global(h4) {
    color: var(--clr-lossless-primary);
    margin-top: 2rem;
    margin-bottom: 0.85rem;
    line-height: 1.3;
  }

  .entry-body :global(h1) { font-size: 1.7rem; }
  .entry-body :global(h2) { font-size: 1.4rem; }
  .entry-body :global(h3) { font-size: 1.18rem; }
  .entry-body :global(h4) { font-size: 1.02rem; color: var(--clr-lossless-accent--brightest); }

  .entry-body :global(p) {
    margin: 0 0 1.1rem 0;
    color: var(--clr-lossless-primary-light);
  }

  .entry-body :global(strong) { color: var(--clr-lossless-primary); }

  .entry-body :global(a) {
    color: var(--clr-lossless-accent--brightest);
    text-decoration: none;
    border-bottom: 1px solid rgba(4, 229, 229, 0.25);
    transition: border-color 0.2s;
  }

  .entry-body :global(a:hover) {
    border-bottom-color: var(--clr-lossless-accent--brightest);
  }

  .entry-body :global(ul),
  .entry-body :global(ol) {
    margin: 0 0 1.1rem 0;
    padding-left: 1.5rem;
    color: var(--clr-lossless-primary-light);
  }

  .entry-body :global(ul) { list-style: disc; }
  .entry-body :global(ol) { list-style: decimal; }

  .entry-body :global(li) {
    margin-bottom: 0.4rem;
  }

  .entry-body :global(li > ul),
  .entry-body :global(li > ol) {
    margin-top: 0.4rem;
    margin-bottom: 0.4rem;
  }

  .entry-body :global(blockquote) {
    margin: 0 0 1.1rem 0;
    padding: 0.5rem 1rem;
    border-left: 3px solid rgba(4, 229, 229, 0.4);
    background: rgba(4, 229, 229, 0.04);
    color: var(--clr-lossless-primary-light);
    border-radius: 0 6px 6px 0;
  }

  .entry-body :global(code) {
    font-family: var(--ff-monospace);
    font-size: 0.88em;
    background: rgba(255, 255, 255, 0.06);
    padding: 0.12em 0.35em;
    border-radius: 3px;
    color: var(--clr-lossless-accent--aquamarine);
  }

  .entry-body :global(pre) {
    background: #0d1117;
    border: 1px solid var(--clr-border-subtle);
    border-radius: 8px;
    padding: 1rem 1.1rem;
    margin: 0 0 1.25rem 0;
    overflow-x: auto;
    font-size: 0.85rem;
    line-height: 1.55;
  }

  .entry-body :global(pre code) {
    background: transparent;
    padding: 0;
    color: #e2e8f0;
    font-size: inherit;
  }

  .entry-body :global(hr) {
    border: none;
    border-top: 1px solid var(--clr-border-subtle);
    margin: 2rem 0;
  }

  .entry-body :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    margin: 1rem 0;
  }

  .entry-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 0 0 1.25rem 0;
    font-size: 0.92rem;
  }

  .entry-body :global(th),
  .entry-body :global(td) {
    padding: 0.5rem 0.75rem;
    text-align: left;
    border-bottom: 1px solid var(--clr-border-subtle);
  }

  .entry-body :global(th) {
    color: var(--clr-lossless-primary);
    font-weight: 600;
    background: rgba(255, 255, 255, 0.03);
  }
</style>
