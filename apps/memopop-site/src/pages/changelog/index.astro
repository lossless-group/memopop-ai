---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/Header.astro';
import GuiCallout from '@components/GuiCallout.astro';
import { readProvenance, threadStyle, pickDate, pickString, fmtDate, fromKindLabel } from '@lib/provenance';

const base = import.meta.env.BASE_URL;

interface Row {
  source: string;
  sourceKind: string;
  slug: string;
  url: string;
  title: string;
  summary: string;
  date: Date | null;
  version?: string;
  category?: string;
  tags: string[];
}

const rawEntries = await getCollection('changelog');

const rows: Row[] = rawEntries.map((entry) => {
  const data = entry.data as Record<string, unknown>;
  const { from, fromKind } = readProvenance(data, 'memopop-ai');
  const slugWithinPeer = entry.id.replace(new RegExp(`^${from}/`), '');
  return {
    source: from,
    sourceKind: fromKind,
    slug: slugWithinPeer,
    url: `${base}changelog/${from}/${slugWithinPeer}/`,
    title: pickString(data, 'title') ?? slugWithinPeer,
    summary: pickString(data, 'lede', 'summary', 'description') ?? '',
    date: pickDate(data, entry.id),
    version: pickString(data, 'at_semantic_version', 'semantic_version'),
    category: pickString(data, 'category'),
    tags: Array.isArray(data.tags) ? (data.tags as string[]) : [],
  };
});

rows.sort((a, b) => (b.date?.getTime() ?? 0) - (a.date?.getTime() ?? 0));

const counts = new Map<string, { count: number; kind: string }>();
for (const r of rows) {
  const c = counts.get(r.source);
  if (c) c.count++;
  else counts.set(r.source, { count: 1, kind: r.sourceKind });
}

const filterOptions = [...counts.entries()]
  .map(([slug, { count, kind }]) => ({ slug, count, kind }))
  .sort((a, b) => {
    const order = { parent: 0, app: 1, package: 2 } as Record<string, number>;
    if ((order[a.kind] ?? 9) !== (order[b.kind] ?? 9)) return (order[a.kind] ?? 9) - (order[b.kind] ?? 9);
    return a.slug.localeCompare(b.slug);
  });
---

<BaseLayout title="Changelog — MemoPop AI" description="Every meaningful change across the MemoPop AI monorepo, surfaced by app and package.">
  <Header active="changelog" />

  <main class="archive">
    <div class="container-narrow">
      <header class="archive__head">
        <p class="eyebrow">Ship log</p>
        <h1 class="archive__title gradient-text">Changelog</h1>
        <p class="archive__lede">
          Every meaningful change across the monorepo — the
          <a href="https://github.com/lossless-group/investment-memo-orchestrator" target="_blank" rel="noopener">orchestrator</a>
          (engine), the desktop client, this site, and the workspace itself. Discovered automatically;
          adding a new app makes it appear here.
        </p>
      </header>

      <div class="filters" id="source-filters" role="tablist" aria-label="Filter by source">
        <button class="filter-pill is-active" data-filter="all" role="tab" aria-selected="true">
          All <span class="filter-pill__count">{rows.length}</span>
        </button>
        {filterOptions.map((opt) => (
          <button
            class="filter-pill"
            data-filter={opt.slug}
            role="tab"
            aria-selected="false"
            style={threadStyle(opt.slug)}
          >
            <span class="filter-pill__dot" aria-hidden="true"></span>
            {opt.slug}
            <span class="filter-pill__count">{opt.count}</span>
            <span class="filter-pill__kind mono">{fromKindLabel(opt.kind)}</span>
          </button>
        ))}
      </div>

      {rows.length === 0 ? (
        <div class="archive__empty">
          <p>No published changelog entries yet.</p>
        </div>
      ) : (
        <ul class="entries" data-pagefind-ignore="all">
          {rows.map((row) => (
            <li class="entry" data-source={row.source}>
              <div class="entry__meta">
                <span class="from-tag mono" style={threadStyle(row.source)}>{row.source}</span>
                {row.date && <time class="entry__date mono" datetime={row.date.toISOString()}>{fmtDate(row.date)}</time>}
                {row.version && <span class="pill mono">v{row.version}</span>}
                {row.category && <span class="entry__category">{row.category}</span>}
              </div>
              <a class="entry__link" href={row.url}>
                <h2 class="entry__title">{row.title}</h2>
                {row.summary && <p class="entry__summary">{row.summary}</p>}
              </a>
              {row.tags.length > 0 && (
                <div class="entry__tags">
                  {row.tags.slice(0, 6).map((t) => <span class="tag mono">{t}</span>)}
                  {row.tags.length > 6 && <span class="tag tag--more mono">+{row.tags.length - 6}</span>}
                </div>
              )}
            </li>
          ))}
        </ul>
      )}

      <GuiCallout variant="compact" />
    </div>
  </main>
</BaseLayout>

<script>
  const bar = document.getElementById('source-filters');
  if (bar) {
    bar.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      const btn = target.closest('button[data-filter]') as HTMLButtonElement | null;
      if (!btn) return;
      const filter = btn.dataset.filter ?? 'all';
      bar.querySelectorAll('button').forEach((b) => {
        const active = b === btn;
        b.classList.toggle('is-active', active);
        b.setAttribute('aria-selected', active ? 'true' : 'false');
      });
      document.querySelectorAll<HTMLElement>('.entry').forEach((el) => {
        el.style.display = filter === 'all' || el.dataset.source === filter ? '' : 'none';
      });
    });
  }
</script>

<style>
  .archive {
    padding: 3rem 0 5rem;
  }

  .archive__head { margin-bottom: 2.5rem; }

  .archive__title {
    font-size: clamp(2.25rem, 5vw, 3.25rem);
    margin: 0.5rem 0 1rem;
  }

  .archive__lede {
    font-size: 1.1rem;
    color: var(--color-text-soft);
    line-height: 1.65;
    max-width: 65ch;
  }

  .archive__lede a {
    color: var(--color-accent);
    border-bottom: 1px solid color-mix(in oklab, var(--color-accent) 35%, transparent);
  }
  .archive__lede a:hover { color: var(--color-accent-soft); }

  .archive__empty {
    padding: 3rem 0;
    color: var(--color-text-dim);
    text-align: center;
  }

  .filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2rem;
    padding: 0.85rem 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .filter-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.85rem;
    border: 1px solid var(--color-border-strong);
    background: color-mix(in oklab, var(--color-text) 4%, transparent);
    color: var(--color-text-soft);
    border-radius: var(--radius-pill);
    font-family: var(--font__mono);
    font-size: 0.78rem;
    font-weight: 500;
    cursor: pointer;
    transition: color var(--transition-fast), border-color var(--transition-fast), background var(--transition-fast);
  }

  .filter-pill__dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--from-thread, var(--thread__default));
  }

  .filter-pill__count {
    color: var(--color-text-dim);
    font-size: 0.72rem;
  }
  .filter-pill__kind {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-faint);
    margin-left: 0.15rem;
  }

  .filter-pill:hover {
    color: var(--color-text);
    border-color: var(--color-border-accent);
  }

  .filter-pill.is-active {
    background: color-mix(in oklab, var(--from-thread, var(--color-accent)) 12%, transparent);
    border-color: color-mix(in oklab, var(--from-thread, var(--color-accent)) 50%, transparent);
    color: var(--from-thread, var(--color-accent));
  }
  .filter-pill.is-active .filter-pill__count,
  .filter-pill.is-active .filter-pill__kind { color: inherit; opacity: 0.85; }

  .entries {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin: 0;
    padding: 0;
  }

  .entry {
    padding: 1.25rem 1.5rem;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    transition: border-color var(--transition-fast), transform var(--transition-fast);
  }

  .entry:hover {
    border-color: var(--color-border-accent);
    transform: translateY(-1px);
  }

  .entry__meta {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    margin-bottom: 0.6rem;
    flex-wrap: wrap;
    font-size: 0.78rem;
  }

  .entry__date {
    color: var(--color-text-dim);
    font-size: 0.78rem;
  }

  .entry__category {
    color: var(--color-text-dim);
    font-size: 0.78rem;
  }

  .entry__link {
    display: block;
    color: inherit;
  }

  .entry__title {
    font-family: var(--font__display);
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 0 0 0.4rem 0;
    line-height: 1.35;
  }

  .entry__link:hover .entry__title {
    color: var(--color-accent);
  }

  .entry__summary {
    font-size: 0.95rem;
    color: var(--color-text-soft);
    line-height: 1.6;
    margin: 0;
  }

  .entry__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-top: 0.85rem;
  }

  .tag {
    font-size: 0.7rem;
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    background: color-mix(in oklab, var(--color-text) 4%, transparent);
    color: var(--color-text-dim);
  }
  .tag--more { font-style: italic; }

  @media (max-width: 600px) {
    .entry { padding: 1rem 1.1rem; }
    .entry__title { font-size: 1.05rem; }
  }
</style>
