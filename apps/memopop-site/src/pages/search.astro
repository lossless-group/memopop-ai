---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/Header.astro';
import SearchBox from '@components/SearchBox.astro';
---

<BaseLayout title="Search — MemoPop AI" description="Search across changelog entries and workspace notes.">
  <Header active="search" />

  <main class="search-page">
    <div class="container-narrow">
      <header class="search-page__head">
        <p class="eyebrow">Find anything</p>
        <h1 class="search-page__title gradient-text">Search</h1>
        <p class="search-page__lede">
          Indexed across the changelog and workspace notes. Filter by source app or
          kind once you have results. Press <kbd class="mono">/</kbd> from anywhere
          to focus the search box in the header.
        </p>
      </header>

      <SearchBox autoFocus />

      <p class="search-page__hint mono">
        Tip: search runs on a static index built at deploy time. In <code>astro dev</code>
        the index isn't generated — run <code>bun run build &amp;&amp; bun run preview</code>
        to test locally.
      </p>
    </div>
  </main>
</BaseLayout>

<style>
  .search-page { padding: 3rem 0 6rem; }
  .search-page__head { margin-bottom: 2.5rem; }
  .search-page__title {
    font-size: clamp(2.25rem, 5vw, 3.25rem);
    margin: 0.5rem 0 1rem;
  }
  .search-page__lede {
    font-size: 1.1rem;
    color: var(--color-text-soft);
    line-height: 1.65;
    max-width: 65ch;
  }
  .search-page__lede kbd {
    font-size: 0.78rem;
    padding: 1px 7px;
    border-radius: 4px;
    border: 1px solid var(--color-border-strong);
    background: var(--color-bg-soft);
    color: var(--color-text);
  }
  .search-page__hint {
    margin-top: 2rem;
    color: var(--color-text-faint);
    font-size: 0.78rem;
  }
  .search-page__hint code {
    font-family: var(--font__mono);
    background: color-mix(in oklab, var(--color-text) 5%, transparent);
    padding: 1px 6px;
    border-radius: 4px;
  }
</style>
