---
import BaseLayout from '../layouts/BaseLayout.astro';

const stats = [
  { value: "33", label: "Specialized Agents" },
  { value: "9", label: "VC Firms Using It" },
];

const pipeline = [
  { step: "1", name: "Deck or Dataroom Analysis", desc: "Thorough dataroom object identification and deconstruction. Pull KPI timelines, key charts, properly identify slide messages, and extract primary source information. Classify 12+ document types with confidence scoring." },
  { step: "2", name: "Web Research", desc: "Multi-query research via Perplexity Sonar Pro with section-specific @source targeting. Crunchbase, PitchBook, Statista, CB Insights." },
  { step: "3", name: "Outline Loading", desc: "Proprietary document structure loaded before writing begins. Guiding questions, vocabulary and phrasing, dos and don'ts -- your firm's voice and analytical framework baked into every section." },
  { step: "4", name: "Section Writing", desc: "Individual sections drafted by specialized writing agents shaped by the loaded outline. Each section processed independently to avoid timeouts." },
  { step: "5", name: "Multi-Agent Enrichment", desc: "Trademark links, social profiles, citations, competitive context. Each enrichment agent works on section files, not assembled content." },
  { step: "6", name: "Fact Checkers and Source Verifiers", desc: "Three-step extract → verify (Perplexity) → correct (Claude) pipeline. Full traceability for every claim." },
  { step: "7", name: "Scorecard Evaluation", desc: "Firm-specific evaluation criteria applied after writing. Team velocity, market timing, defensibility -- whatever your IC actually debates. Scores and flags feed back into revision." },
  { step: "8", name: "Validation for Iteration and Quality Assurance", desc: "Quality scoring against analytical standards. Threshold of 8/10 for auto-finalization. Detailed improvement suggestions below threshold." },
  { step: "9", name: "Branded, Multi-Format Exports", desc: "Branded HTML/PDF in light and dark modes. Firm-scoped configs for colors, fonts, logos. One-pager summaries." },
];

const supporters = [
  { name: "Hypernova Capital", url: "https://www.hypernova.capital" },
  { name: "Avalanche VC", url: "https://avalanche.vc" },
  { name: "Emerge Capital", url: "https://emergecapital.vc" },
  { name: "Humain VC", url: "https://humain.vc" },
  { name: "DarkMatter VC", url: "https://darkmatter.vc" },
  { name: "Banner VC", url: "https://banner.vc" },
  { name: "Motley Fool Ventures", url: "https://foolventures.com/" },
  { name: "Two Magnolias", url: "https://www.twomagnolias.co.uk/" },
  { name: "Alpha Partners", url: "https://alphapartners.com/" },
];

const orchestratorRepo = "https://github.com/lossless-group/investment-memo-orchestrator";
const monorepoRepo = "https://github.com/lossless-group/memopop-ai";
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="MemoPop AI — Multi-agent investment memo orchestrator">
  <main class="main-content">
    <div class="container">

      <div class="hero">
        <div class="hero-badge">Open Source</div>
        <h1 class="hero-title">MemoPop AI</h1>
        <p class="hero-sublede">Multi-agent investment memo orchestrator.</p>
        <p class="hero-lede">Turn a company name into an institutional-quality investment memo with <strong class="highlight">33 specialized AI agents</strong>, premium data sources, full citation trails, and firm-specific branded exports.</p>
        <div class="hero-actions">
          <a href={orchestratorRepo} target="_blank" rel="noopener" class="btn-primary">
            <svg class="btn-icon" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
            View on GitHub
          </a>
          <a href="#pipeline" class="btn-secondary">See the Pipeline</a>
          <a href={`${base}changelog`} class="btn-tertiary">Changelog →</a>
        </div>
        <div class="hero-supporters">
          <span class="supporters-label">Supported by</span>
          {supporters.map((s, i) => (
            <Fragment>
              <a href={s.url} target="_blank" rel="noopener" class="supporter-link">{s.name}</a>
              {i < supporters.length - 1 && <span class="supporter-sep">·</span>}
            </Fragment>
          ))}
        </div>
      </div>

      <div class="separator"></div>

      <section class="time-section">
        <div class="time-comparison">
          <div class="time-before">
            <span class="time-value-strike">1–2 days</span>
            <span class="time-label">per memo</span>
          </div>
          <span class="time-arrow">→</span>
          <div class="time-after">
            <span class="time-value-pop">10–15 min</span>
            <span class="time-label">to a first draft</span>
          </div>
        </div>
        <div class="time-combined">
          <span class="time-value-combined">Analyst + MemoPop = 1–2 hours</span>
          <span class="time-label-combined">to a polished, cited, firm-branded investment memo</span>
        </div>
        <div class="time-outcomes">
          <span class="outcome">Cover more opportunities</span>
          <span class="outcome-sep">·</span>
          <span class="outcome">Create materials in time to syndicate</span>
          <span class="outcome-sep">·</span>
          <span class="outcome">Create great artifacts and datasets for LP reporting and fundraising</span>
        </div>
      </section>

      <section class="stats-section">
        <div class="stats-grid">
          {stats.map(stat => (
            <div class="stat-card">
              <span class="stat-value">{stat.value}</span>
              <span class="stat-label">{stat.label}</span>
            </div>
          ))}
        </div>
      </section>

      <div class="separator"></div>

      <section class="why-section">
        <h2 class="section-title">Why This Exists</h2>
        <div class="why-grid">
          <div class="why-card">
            <h3>Chats with Prompts Won't Make You Great</h3>
            <p>Asking ChatGPT to "write an investment memo" produces generic, uncited, surface-level output. Real investment memos require structured research from authoritative sources, firm-specific evaluation criteria, and analytical rigor that no single prompt can deliver.</p>
          </div>
          <div class="why-card">
            <h3>VC Analysis Takes Days</h3>
            <p>A quality investment memo takes 2-5 days of research, writing, and revision -- time most emerging managers don't have. Most of that work is pulling Crunchbase data, sizing TAM from Statista, cross-referencing team backgrounds, finding relevant charts, sourcing content from experts... tasks AI agents can do in minutes.</p>
          </div>
          <div class="why-card">
            <h3>Proprietary Thinking Matters</h3>
            <p>Every fund evaluates deals differently. Hypernova weighs technical defensibility differently than Avalanche weighs market timing. Generic AI can't reflect your IC's actual decision framework. Scorecards and firm-scoped templates make your proprietary criteria the backbone of every memo.</p>
          </div>
        </div>
      </section>

      <div class="separator"></div>

      <section id="pipeline" class="pipeline-section">
        <h2 class="section-title">The Pipeline</h2>
        <p class="section-lede">Not a chatbot. A coordinated pipeline of specialized agents, each producing research analyst artifacts that serve as a source of truth, provide full retraceability, and act as a fallback for future iterations.</p>

        <div class="cast">
          <div class="cast-card cast-extractor">
            <span class="cast-icon">⚙</span>
            <div class="cast-info">
              <span class="cast-name">Extractor</span>
              <span class="cast-detail">Deck parsing, dataroom analysis, KPI extraction</span>
            </div>
          </div>
          <div class="cast-arrow">→</div>
          <div class="cast-card cast-researcher">
            <span class="cast-icon">⚲</span>
            <div class="cast-info">
              <span class="cast-name">Researcher</span>
              <span class="cast-detail">Perplexity Sonar Pro with premium @source targeting</span>
            </div>
          </div>
          <div class="cast-arrow">→</div>
          <div class="cast-card cast-writer">
            <span class="cast-icon">✍</span>
            <div class="cast-info">
              <span class="cast-name">Writer</span>
              <span class="cast-detail">GPT drafts sections from research artifacts</span>
            </div>
          </div>
          <div class="cast-arrow">→</div>
          <div class="cast-card cast-validator">
            <span class="cast-icon">⚠</span>
            <div class="cast-info">
              <span class="cast-name">Validator</span>
              <span class="cast-detail">Fact-checks claims, verifies sources, scores quality</span>
            </div>
          </div>
          <div class="cast-arrow">→</div>
          <div class="cast-card cast-editor">
            <span class="cast-icon">✎</span>
            <div class="cast-info">
              <span class="cast-name">Editor</span>
              <span class="cast-detail">Claude refines, enforces quality, polishes output</span>
            </div>
          </div>
          <div class="cast-arrow">→</div>
          <div class="cast-card cast-output">
            <span class="cast-icon">✦</span>
            <div class="cast-info">
              <span class="cast-name">Versioned Output</span>
              <span class="cast-detail">Artifacts in versioned folders. Easy to iterate, with "best of versions" out of the box.</span>
            </div>
          </div>
        </div>
        <div class="cast-human">
          <span class="cast-human-icon">◉</span>
          <span class="cast-human-text"><strong>You</strong> have oversight at every step. Review artifacts, re-run agents, improve sections, integrate across versions. The pipeline produces drafts -- you make decisions.</span>
        </div>

        <div class="pipeline-orchestrator">
          <div class="orchestrator-label">
            <span class="orch-icon">◎</span> Orchestrator
            <span class="orch-sub">LangGraph supervisor coordinates all agents, manages state, handles retries</span>
          </div>
          <div class="pipeline-steps">
            {pipeline.map((step, i) => (
              <Fragment>
                <div class="flow-step">
                  <div class="flow-number">{step.step}</div>
                  <div class="flow-content">
                    <h3 class="flow-name">{step.name}</h3>
                    <p class="flow-desc">{step.desc}</p>
                  </div>
                </div>
                {i < pipeline.length - 1 && (
                  <div class="flow-connector">
                    <div class="flow-line"></div>
                    <div class="flow-arrow">▾</div>
                  </div>
                )}
              </Fragment>
            ))}
          </div>
        </div>
      </section>

      <div class="separator"></div>

      <section class="cli-section">
        <h2 class="section-title">One Command to Start</h2>
        <div class="cli-block">
          <div class="cli-header">
            <span class="cli-dot red"></span>
            <span class="cli-dot yellow"></span>
            <span class="cli-dot green"></span>
            <span class="cli-title">terminal</span>
          </div>
          <pre class="cli-code"><code>$ memopop

╭─────────────────────────────────────────────────────────╮
│                                                         │
│   Investment Memo Orchestrator                          │
│   v0.5.3 · 33 agents · Powered by Claude + Perplexity  │
│                                                         │
╰─────────────────────────────────────────────────────────╯

? What would you like to do?
  ❯ Generate a new investment memo
    Generate a one-pager summary
    Export an existing memo (HTML / PDF / Word)
    Improve a specific section
    Integrate content from versions
    Run a specific agent</code></pre>
        </div>
        <p class="cli-note">No flags, no file paths. The interactive CLI auto-discovers firms, deals, and versions.</p>
      </section>

      <div class="separator"></div>

      <section class="cta-dual">
        <div class="cta-card cta-opensource">
          <h2>Open Source. Bring Your Own Keys.</h2>
          <p>MemoPop runs on your machine with your API keys. Claude for analysis and writing, Perplexity Sonar Pro for cited research, or DuckDuckGo as a free fallback. Your deal data stays yours.</p>
          <div class="cta-actions">
            <a href={orchestratorRepo} target="_blank" rel="noopener" class="btn-primary">
              <svg class="btn-icon" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
              Get Started on GitHub
            </a>
            <a href={`${orchestratorRepo}#similar-services`} target="_blank" rel="noopener" class="btn-secondary">Compare Alternatives</a>
          </div>
        </div>
        <div class="cta-card cta-human">
          <h2>Not a GitHub Vibe Coder?</h2>
          <p>Hit us up. We can turn around a draft same day, sometimes in 10-15 minutes.</p>
          <div class="cta-contacts">
            <a href="https://x.com/losslessgroup" target="_blank" rel="noopener" class="contact-link">
              <svg class="btn-icon" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              @losslessgroup
            </a>
            <a href="https://x.com/mpstaton" target="_blank" rel="noopener" class="contact-link">
              <svg class="btn-icon" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              @mpstaton
            </a>
          </div>
        </div>
      </section>

      <footer class="page-footer">
        <p>
          <a href={`${base}changelog`}>Changelog</a> ·
          Built by <a href="https://www.lossless.group" target="_blank" rel="noopener">The Lossless Group</a> ·
          Source for this site: <a href={monorepoRepo} target="_blank" rel="noopener">lossless-group/memopop-ai</a>
        </p>
      </footer>

    </div>
  </main>
</BaseLayout>

<style>
  .main-content {
    min-height: 100vh;
    padding: 2rem 0;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .separator {
    height: 1px;
    background: linear-gradient(90deg,
      transparent 0%,
      rgba(4, 229, 229, 0.25) 50%,
      transparent 100%);
    margin: 1rem 0;
  }

  .hero {
    padding: 3rem 0 2.5rem;
  }

  .hero-badge {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--clr-lossless-accent--aquamarine);
    background: rgba(111, 255, 214, 0.1);
    border: 1px solid rgba(111, 255, 214, 0.25);
    padding: 0.25rem 0.75rem;
    border-radius: 4px;
    margin-bottom: 1rem;
  }

  .hero-title {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 700;
    margin: 0 0 1.25rem 0;
    background: linear-gradient(135deg, var(--clr-lossless-accent--brightest) 0%, var(--clr-lossless-accent--purple) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-sublede {
    font-size: 1.5rem;
    font-weight: 600;
    color: #cbd5e1;
    margin: 0 0 0.75rem 0;
  }

  .hero-lede {
    font-size: 1.25rem;
    color: var(--clr-lossless-primary-light);
    line-height: 1.8;
    max-width: 850px;
    margin: 0 0 2rem 0;
  }

  .highlight {
    color: var(--clr-lossless-accent--brightest);
  }

  .hero-actions, .cta-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }

  .btn-primary {
    background: var(--clr-lossless-accent--brightest);
    color: var(--clr-primary-bg);
    padding: 0.75rem 1.5rem;
    border-radius: 6px;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    transition: opacity 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .btn-primary:hover { opacity: 0.85; }
  .btn-icon { flex-shrink: 0; }

  .btn-secondary {
    background: transparent;
    color: var(--clr-lossless-accent--aquamarine);
    border: 1px solid var(--clr-lossless-accent--aquamarine);
    padding: 0.75rem 1.5rem;
    border-radius: 6px;
    text-decoration: none;
    font-weight: 500;
    font-size: 0.95rem;
    transition: background 0.2s;
  }

  .btn-secondary:hover { background: rgba(111, 255, 214, 0.08); }

  .btn-tertiary {
    background: transparent;
    color: var(--clr-lossless-primary-light);
    padding: 0.75rem 0.5rem;
    text-decoration: none;
    font-weight: 500;
    font-size: 0.95rem;
    transition: color 0.2s;
    align-self: center;
  }

  .btn-tertiary:hover { color: var(--clr-lossless-accent--brightest); }

  .hero-supporters {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .supporters-label {
    font-size: 0.8rem;
    color: var(--clr-lossless-primary-dim);
    font-weight: 500;
  }

  .supporter-link {
    font-size: 0.85rem;
    color: var(--clr-lossless-primary-light);
    text-decoration: none;
    transition: color 0.2s;
  }

  .supporter-link:hover {
    color: var(--clr-lossless-accent--brightest);
  }

  .supporter-sep {
    color: var(--clr-lossless-primary-dimmer);
  }

  section {
    padding: 3rem 0;
  }

  .section-title {
    font-size: 1.6rem;
    font-weight: 600;
    color: var(--clr-lossless-primary);
    margin: 0 0 0.75rem 0;
  }

  .section-lede {
    font-size: 1.1rem;
    color: var(--clr-lossless-primary-light);
    line-height: 1.7;
    max-width: 800px;
    margin: 0 0 2rem 0;
  }

  .time-section {
    padding: 2.5rem 0;
    text-align: center;
  }

  .time-comparison {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    margin-bottom: 2rem;
  }

  .time-before, .time-after {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }

  .time-value-strike {
    font-size: 2.75rem;
    font-weight: 700;
    color: var(--clr-lossless-primary-dim);
    text-decoration: line-through;
    opacity: 0.5;
  }

  .time-arrow {
    font-size: 2rem;
    color: var(--clr-lossless-accent--brightest);
    font-weight: 700;
  }

  .time-value-pop {
    font-size: 2.75rem;
    font-weight: 700;
    color: var(--clr-lossless-accent--brightest);
  }

  .time-label {
    font-size: 0.9rem;
    color: var(--clr-lossless-primary-light);
  }

  .time-combined {
    margin-bottom: 1.5rem;
  }

  .time-value-combined {
    display: block;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--clr-lossless-accent--aquamarine);
    margin-bottom: 0.35rem;
  }

  .time-label-combined {
    font-size: 1rem;
    color: var(--clr-lossless-primary-light);
  }

  .time-outcomes {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .outcome {
    font-size: 1rem;
    font-weight: 600;
    color: #cbd5e1;
  }

  .outcome-sep {
    color: var(--clr-lossless-primary-dimmer);
  }

  .stats-section {
    padding: 2rem 0;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    max-width: 500px;
    margin: 0 auto;
  }

  .stat-card {
    text-align: center;
    padding: 1.5rem;
  }

  .stat-value {
    display: block;
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--clr-lossless-accent--brightest);
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  .stat-label {
    font-size: 0.85rem;
    color: var(--clr-lossless-primary-light);
    font-weight: 500;
  }

  .why-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .why-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(4, 229, 229, 0.12);
    border-radius: 10px;
    padding: 1.5rem;
  }

  .why-card h3 {
    font-size: 1.1rem;
    color: var(--clr-lossless-accent--brightest);
    margin: 0 0 0.75rem 0;
  }

  .why-card p {
    font-size: 0.95rem;
    color: var(--clr-lossless-primary-light);
    line-height: 1.65;
    margin: 0;
  }

  .cast {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .cast-card {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.75rem 1rem;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .cast-extractor { border-color: rgba(234, 179, 8, 0.3); }
