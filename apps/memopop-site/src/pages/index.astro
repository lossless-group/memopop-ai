---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/Header.astro';
import GuiCallout from '@components/GuiCallout.astro';
import MemoMark from '@components/MemoMark.astro';
import { readProvenance, threadStyle, pickDate, pickString, fmtDate } from '@lib/provenance';

const stats = [
  { value: '33', label: 'Specialized agents' },
  { value: '9', label: 'VC firms using it' },
  { value: '10–15m', label: 'To a first draft' },
];

const pipeline = [
  { step: '1', name: 'Deck or dataroom analysis', desc: "Thorough dataroom object identification and deconstruction. Pull KPI timelines, key charts, properly identify slide messages, and extract primary source information. Classify 12+ document types with confidence scoring." },
  { step: '2', name: 'Web research', desc: 'Multi-query research via Perplexity Sonar Pro with section-specific @source targeting. Crunchbase, PitchBook, Statista, CB Insights.' },
  { step: '3', name: 'Outline loading', desc: "Proprietary document structure loaded before writing begins. Guiding questions, vocabulary and phrasing, dos and don'ts — your firm's voice and analytical framework baked into every section." },
  { step: '4', name: 'Section writing', desc: 'Individual sections drafted by specialized writing agents shaped by the loaded outline. Each section processed independently to avoid timeouts.' },
  { step: '5', name: 'Multi-agent enrichment', desc: 'Trademark links, social profiles, citations, competitive context. Each enrichment agent works on section files, not assembled content.' },
  { step: '6', name: 'Fact checkers and source verifiers', desc: 'Three-step extract → verify (Perplexity) → correct (Claude) pipeline. Full traceability for every claim.' },
  { step: '7', name: 'Scorecard evaluation', desc: 'Firm-specific evaluation criteria applied after writing. Team velocity, market timing, defensibility — whatever your IC actually debates. Scores and flags feed back into revision.' },
  { step: '8', name: 'Validation for iteration and quality assurance', desc: 'Quality scoring against analytical standards. Threshold of 8/10 for auto-finalization. Detailed improvement suggestions below threshold.' },
  { step: '9', name: 'Branded, multi-format exports', desc: 'Branded HTML/PDF in light and dark modes. Firm-scoped configs for colors, fonts, logos. One-pager summaries.' },
];

const supporters = [
  { name: 'Hypernova Capital', url: 'https://www.hypernova.capital' },
  { name: 'Avalanche VC', url: 'https://avalanche.vc' },
  { name: 'Emerge Capital', url: 'https://emergecapital.vc' },
  { name: 'Humain VC', url: 'https://humain.vc' },
  { name: 'DarkMatter VC', url: 'https://darkmatter.vc' },
  { name: 'Banner VC', url: 'https://banner.vc' },
  { name: 'Motley Fool Ventures', url: 'https://foolventures.com/' },
  { name: 'Two Magnolias', url: 'https://www.twomagnolias.co.uk/' },
  { name: 'Alpha Partners', url: 'https://alphapartners.com/' },
];

const cast = [
  { icon: '⚙', accent: '--color__amber', name: 'Extractor', desc: 'Deck parsing, dataroom analysis, KPI extraction' },
  { icon: '⚲', accent: '--color__cyan-electric', name: 'Researcher', desc: 'Perplexity Sonar Pro with premium @source targeting' },
  { icon: '✍', accent: '--color__plum-electric', name: 'Writer', desc: 'GPT drafts sections from research artifacts' },
  { icon: '⚠', accent: '--color__amber', name: 'Validator', desc: 'Fact-checks claims, verifies sources, scores quality' },
  { icon: '✎', accent: '--color__cyan-electric', name: 'Editor', desc: 'Claude refines, enforces quality, polishes output' },
  { icon: '✦', accent: '--color__aqua-bright', name: 'Versioned output', desc: 'Artifacts in versioned folders. Easy to iterate, with "best of versions" out of the box.' },
];

const orchestratorRepo = 'https://github.com/lossless-group/investment-memo-orchestrator';
const monorepoRepo = 'https://github.com/lossless-group/memopop-ai';
const base = import.meta.env.BASE_URL;

let latestChangelog: Array<{ url: string; title: string; from: string; date: Date | null; summary: string }> = [];
try {
  const all = await getCollection('changelog');
  latestChangelog = all
    .map((entry) => {
      const data = entry.data as Record<string, unknown>;
      const { from } = readProvenance(data, 'memopop-ai');
      const slug = entry.id.replace(new RegExp(`^${from}/`), '');
      return {
        url: `${base}changelog/${from}/${slug}/`,
        title: pickString(data, 'title') ?? slug,
        summary: pickString(data, 'lede', 'summary', 'description') ?? '',
        from,
        date: pickDate(data, entry.id),
      };
    })
    .sort((a, b) => (b.date?.getTime() ?? 0) - (a.date?.getTime() ?? 0))
    .slice(0, 4);
} catch { /* keep empty */ }
---

<BaseLayout title="MemoPop AI — Multi-agent investment memo orchestrator">
  <Header active="home" />

  <main class="splash">
    <!-- HERO ─────────────────────────────────────────────────────────── -->
    <section class="hero">
      <div class="container">
        <div class="hero__lockup">
          <p class="eyebrow hero__eyebrow">Open source · AI Labs · The Lossless Group</p>
          <div class="hero__title-row">
            <MemoMark size={72} gradient animate class="hero__mark" />
            <h1 class="hero__title">
              <span class="display">Memos that</span>
              <span class="display gradient-text">pop into focus.</span>
            </h1>
          </div>
          <p class="hero__sublede">Multi-agent investment memo orchestrator.</p>
          <p class="hero__lede">
            Turn a company name into an institutional-quality investment memo with
            <strong class="hero__strong">33 specialized agents</strong>, premium data sources,
            full citation trails, and firm-scoped branded exports.
          </p>
          <div class="hero__actions">
            <a href={orchestratorRepo} target="_blank" rel="noopener" class="btn btn--primary">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
              View on GitHub
            </a>
            <a href="#pipeline" class="btn btn--secondary">See the pipeline</a>
            <a href={`${base}changelog`} class="btn btn--ghost">Changelog →</a>
          </div>

          <div class="hero__stats">
            {stats.map((s) => (
              <div class="hero-stat">
                <span class="hero-stat__value gradient-text">{s.value}</span>
                <span class="hero-stat__label">{s.label}</span>
              </div>
            ))}
          </div>

          <div class="hero__supporters">
            <span class="hero__supporters-label mono">Supported by</span>
            {supporters.map((s, i) => (
              <Fragment>
                <a href={s.url} target="_blank" rel="noopener" class="hero__supporter">{s.name}</a>
                {i < supporters.length - 1 && <span class="hero__supporter-sep" aria-hidden="true">·</span>}
              </Fragment>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- TIME ─────────────────────────────────────────────────────────── -->
    <section class="time">
      <div class="container-narrow time__inner">
        <div class="time__row">
          <div class="time__before">
            <span class="time__strike">1–2 days</span>
            <span class="time__sub">per memo</span>
          </div>
          <span class="time__arrow" aria-hidden="true">→</span>
          <div class="time__after">
            <span class="time__pop gradient-text">10–15 min</span>
            <span class="time__sub">to a first draft</span>
          </div>
        </div>
        <p class="time__combined">
          <span class="time__combined-value">Analyst + MemoPop = 1–2 hours</span>
          <span class="time__combined-sub">to a polished, cited, firm-branded investment memo.</span>
        </p>
        <ul class="time__outcomes">
          <li>Cover more opportunities</li>
          <li>Create materials in time to syndicate</li>
          <li>Generate datasets for LP reporting and fundraising</li>
        </ul>
      </div>
    </section>

    <!-- WHY ──────────────────────────────────────────────────────────── -->
    <section class="why">
      <div class="container">
        <header class="section-head">
          <p class="eyebrow">Why this exists</p>
          <h2 class="section-head__title">Three reasons a chat-prompt won't do.</h2>
        </header>
        <div class="why__grid">
          <article class="why-card">
            <span class="why-card__num mono">01</span>
            <h3 class="why-card__title">Chats with prompts won't make you great</h3>
            <p class="why-card__body">
              Asking ChatGPT to "write an investment memo" produces generic, uncited, surface-level output.
              Real memos need structured research from authoritative sources, firm-specific evaluation criteria,
              and analytical rigor that no single prompt can deliver.
            </p>
          </article>
          <article class="why-card">
            <span class="why-card__num mono">02</span>
            <h3 class="why-card__title">VC analysis takes days</h3>
            <p class="why-card__body">
              A quality memo takes 2–5 days of research, writing, and revision — time most emerging managers
              don't have. Most of that work is pulling Crunchbase data, sizing TAM from Statista, cross-referencing
              team backgrounds, sourcing experts… tasks AI agents can do in minutes.
            </p>
          </article>
          <article class="why-card">
            <span class="why-card__num mono">03</span>
            <h3 class="why-card__title">Proprietary thinking matters</h3>
            <p class="why-card__body">
              Every fund evaluates deals differently. Generic AI can't reflect your IC's actual decision framework.
              Scorecards and firm-scoped templates make your proprietary criteria the backbone of every memo.
            </p>
          </article>
        </div>
      </div>
    </section>

    <!-- PIPELINE ─────────────────────────────────────────────────────── -->
    <section id="pipeline" class="pipeline">
      <div class="container">
        <header class="section-head">
          <p class="eyebrow">The pipeline</p>
          <h2 class="section-head__title">Not a chatbot. A coordinated system.</h2>
          <p class="section-head__lede">
            Specialized agents, each producing research artifacts that serve as a source of truth,
            full retraceability, and a fallback for future iterations.
          </p>
        </header>

        <div class="cast">
          {cast.map((c, i) => (
            <Fragment>
              <div class="cast-card" style={`--cast-accent: var(${c.accent});`}>
                <span class="cast-card__icon">{c.icon}</span>
                <div class="cast-card__info">
                  <span class="cast-card__name">{c.name}</span>
                  <span class="cast-card__desc">{c.desc}</span>
                </div>
              </div>
              {i < cast.length - 1 && <span class="cast__arrow" aria-hidden="true">→</span>}
            </Fragment>
          ))}
        </div>

        <div class="cast-human">
          <span class="cast-human__icon" aria-hidden="true">◉</span>
          <span class="cast-human__text">
            <strong>You</strong> have oversight at every step. Review artifacts, re-run agents,
            improve sections, integrate across versions. The pipeline produces drafts — you make decisions.
          </span>
        </div>

        <div class="orchestrator">
          <div class="orchestrator__label">
            <span class="orchestrator__icon" aria-hidden="true">◎</span>
            <span class="orchestrator__name display">Orchestrator</span>
            <span class="orchestrator__sub">LangGraph supervisor — coordinates all agents, manages state, handles retries</span>
          </div>
          <ol class="flow">
            {pipeline.map((step) => (
              <li class="flow-step">
                <span class="flow-step__num mono">{step.step}</span>
                <div class="flow-step__body">
                  <h3 class="flow-step__name">{step.name}</h3>
                  <p class="flow-step__desc">{step.desc}</p>
                </div>
              </li>
            ))}
          </ol>
        </div>
      </div>
    </section>

    <!-- CLI ──────────────────────────────────────────────────────────── -->
    <section class="cli">
      <div class="container-narrow">
        <header class="section-head section-head--center">
          <p class="eyebrow">One command</p>
          <h2 class="section-head__title">From <span class="mono">$ memopop</span> to a draft.</h2>
        </header>
        <div class="cli__block">
          <div class="cli__chrome">
            <span class="cli__dot" data-color="red"></span>
            <span class="cli__dot" data-color="yellow"></span>
            <span class="cli__dot" data-color="green"></span>
            <span class="cli__title mono">terminal</span>
          </div>
          <pre class="cli__code"><code>$ memopop

╭─────────────────────────────────────────────────────────╮
│                                                         │
│   Investment Memo Orchestrator                          │
│   v0.5.3 · 33 agents · Powered by Claude + Perplexity   │
│                                                         │
╰─────────────────────────────────────────────────────────╯

? What would you like to do?
  ❯ Generate a new investment memo
    Generate a one-pager summary
    Export an existing memo (HTML / PDF / Word)
    Improve a specific section
    Integrate content from versions
    Run a specific agent</code></pre>
        </div>
        <p class="cli__note">No flags, no file paths. The interactive CLI auto-discovers firms, deals, and versions.</p>
      </div>
    </section>

    <div class="container">
      <GuiCallout />
    </div>

    <!-- LATEST ───────────────────────────────────────────────────────── -->
    {latestChangelog.length > 0 && (
      <section class="latest">
        <div class="container-narrow">
          <header class="section-head">
            <p class="eyebrow">Latest from the workspace</p>
            <h2 class="section-head__title">Recently shipped.</h2>
          </header>
          <ul class="latest__list">
            {latestChangelog.map((entry) => (
              <li class="latest__item">
                <a href={entry.url} class="latest__link">
                  <div class="latest__meta">
                    <span class="from-tag mono" style={threadStyle(entry.from)}>{entry.from}</span>
                    {entry.date && <time class="mono latest__date">{fmtDate(entry.date)}</time>}
                  </div>
                  <h3 class="latest__title">{entry.title}</h3>
                  {entry.summary && <p class="latest__summary">{entry.summary}</p>}
                </a>
              </li>
            ))}
          </ul>
          <a href={`${base}changelog`} class="latest__more mono">Read the full changelog →</a>
        </div>
      </section>
    )}

    <!-- CTA ──────────────────────────────────────────────────────────── -->
    <section class="cta">
      <div class="container cta__grid">
        <article class="cta-card cta-card--primary">
          <h2 class="cta-card__title">Open source. Bring your own keys.</h2>
          <p class="cta-card__body">
            MemoPop runs on your machine with your API keys. Claude for analysis and writing,
            Perplexity Sonar Pro for cited research, or DuckDuckGo as a free fallback. Your deal
            data stays yours.
          </p>
          <div class="cta-card__actions">
            <a href={orchestratorRepo} target="_blank" rel="noopener" class="btn btn--primary">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
              Get started on GitHub
            </a>
            <a href={`${orchestratorRepo}#similar-services`} target="_blank" rel="noopener" class="btn btn--secondary">Compare alternatives</a>
          </div>
        </article>
        <article class="cta-card cta-card--secondary">
          <h2 class="cta-card__title">Not a GitHub vibe coder?</h2>
          <p class="cta-card__body">
            Hit us up. We can turn around a draft same day, sometimes in 10–15 minutes.
          </p>
          <div class="cta-card__contacts">
            <a href="https://x.com/losslessgroup" target="_blank" rel="noopener" class="cta-card__contact">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              @losslessgroup
            </a>
            <a href="https://x.com/mpstaton" target="_blank" rel="noopener" class="cta-card__contact">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              @mpstaton
            </a>
          </div>
        </article>
      </div>
    </section>

    <footer class="footer">
      <div class="container footer__inner">
        <MemoMark size={20} />
        <p class="footer__text mono">
          <a href={`${base}changelog`}>Changelog</a>
          <span aria-hidden="true">·</span>
          <a href={`${base}context-v`}>Notes</a>
          <span aria-hidden="true">·</span>
          <a href={`${base}search`}>Search</a>
          <span aria-hidden="true">·</span>
          Built by <a href="https://www.lossless.group" target="_blank" rel="noopener">The Lossless Group</a>
          <span aria-hidden="true">·</span>
          <a href={monorepoRepo} target="_blank" rel="noopener">lossless-group/memopop-ai</a>
        </p>
      </div>
    </footer>
  </main>
</BaseLayout>

<style>
  .splash { padding-top: var(--space-4); }

  /* ─── HERO ───────────────────────────────────────────────────────── */
  .hero {
    padding: var(--space-12) 0 var(--space-16);
    position: relative;
  }

  .hero__lockup { max-width: 920px; }

  .hero__eyebrow { margin-bottom: var(--space-6); }

  .hero__title-row {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    margin-bottom: var(--space-5);
    flex-wrap: wrap;
  }

  .hero__mark {
    flex-shrink: 0;
    color: var(--color-accent);
    filter: drop-shadow(0 0 24px color-mix(in oklab, var(--color-accent) 40%, transparent));
  }

  .hero__title {
    font-size: clamp(2.75rem, 6vw, 4.5rem);
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.025em;
    margin: 0;
  }
  .hero__title .display { display: block; }

  .hero__sublede {
    font-family: var(--font__display);
    font-size: clamp(1.25rem, 2.5vw, 1.6rem);
    color: var(--color-text-soft);
    margin: 0 0 var(--space-3) 0;
  }

  .hero__lede {
    font-size: 1.18rem;
    color: var(--color-text-soft);
    line-height: 1.65;
    max-width: 60ch;
    margin: 0 0 var(--space-8) 0;
  }

  .hero__strong {
    color: var(--color-accent);
    font-weight: 700;
  }

  .hero__actions {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
    margin-bottom: var(--space-10);
  }

  .hero__stats {
    display: grid;
    grid-template-columns: repeat(3, max-content);
    gap: var(--space-10);
    margin-bottom: var(--space-10);
    padding: var(--space-5) 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .hero-stat { display: flex; flex-direction: column; gap: 2px; }
  .hero-stat__value {
    font-family: var(--font__display);
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 700;
    line-height: 1;
  }
  .hero-stat__label {
    font-family: var(--font__mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-dim);
  }

  .hero__supporters {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    color: var(--color-text-dim);
  }
  .hero__supporters-label {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-text-faint);
    margin-right: var(--space-2);
  }
  .hero__supporter {
    font-size: 0.85rem;
    color: var(--color-text-soft);
    transition: color var(--transition-fast);
  }
  .hero__supporter:hover { color: var(--color-accent); }
  .hero__supporter-sep { color: var(--color-text-faint); }

  /* ─── BUTTONS ────────────────────────────────────────────────────── */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.4rem;
    border-radius: var(--radius-md);
    font-size: 0.92rem;
    font-weight: 600;
    line-height: 1;
    cursor: pointer;
    transition: transform var(--transition-fast), background var(--transition-fast), color var(--transition-fast), border-color var(--transition-fast), box-shadow var(--transition-fast);
    border: 1px solid transparent;
  }
  .btn--primary {
    background: var(--color-accent);
    color: var(--color-bg);
  }
  .btn--primary:hover {
    transform: translateY(-1px);
    box-shadow: var(--shadow-glow);
  }
  .btn--secondary {
    background: transparent;
    color: var(--color-accent-soft);
    border-color: color-mix(in oklab, var(--color-accent-soft) 50%, transparent);
  }
  .btn--secondary:hover {
    background: color-mix(in oklab, var(--color-accent-soft) 10%, transparent);
    color: var(--color-accent);
    border-color: var(--color-accent);
  }
  .btn--ghost {
    background: transparent;
    color: var(--color-text-soft);
    padding: 0.75rem 0.6rem;
  }
  .btn--ghost:hover { color: var(--color-accent); }

  /* ─── SECTIONS ───────────────────────────────────────────────────── */
  .time, .why, .pipeline, .cli, .latest, .cta {
    padding: var(--space-16) 0;
    border-top: 1px solid var(--color-border);
  }

  .section-head { margin-bottom: var(--space-10); }
  .section-head--center { text-align: center; }
  .section-head__title {
    font-size: clamp(1.85rem, 3.5vw, 2.5rem);
