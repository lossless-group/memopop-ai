---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Multi-agent investment memo orchestrator. From a company name to an institutional-quality investment memo with 33 specialized AI agents." } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`}>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
</head>
<body>
  <slot />
</body>
</html>

<style is:global>
  :root {
    --clr-primary-bg: #0a0a0f;
    --clr-primary-bg-alt: #11111a;
    --clr-lossless-accent--brightest: #04e5e5;
    --clr-lossless-accent--aquamarine: #6FFFD6;
    --clr-lossless-accent--purple: #BF23F7;
    --clr-lossless-primary: #f1f5f9;
    --clr-lossless-primary-light: #94a3b8;
    --clr-lossless-primary-dim: #64748b;
    --clr-lossless-primary-dimmer: #475569;
    --clr-border-subtle: rgba(255, 255, 255, 0.08);

    --ff-sans: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    --ff-monospace: 'JetBrains Mono', 'Fira Code', monospace;

    --radius-sm: 4px;
    --radius-md: 8px;
    --radius-lg: 12px;
  }

  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: var(--ff-sans);
    font-size: 16px;
    line-height: 1.6;
    color: var(--clr-lossless-primary);
    background: var(--clr-primary-bg);
    min-height: 100vh;
  }

  h1, h2, h3, h4, h5, h6 {
    line-height: 1.2;
    font-weight: 700;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  ul {
    list-style: none;
  }

  img {
    max-width: 100%;
    height: auto;
  }
</style>
