{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "shell:default",
    "dialog:default",
    "store:default",
    "fs:default",
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        { "path": "**", "app": true }
      ]
    },
    {
      "identifier": "opener:allow-reveal-item-in-dir",
      "allow": [
        { "path": "**" }
      ]
    }
  ]
}